{
  "name": "wechat-claude-assistant",
  "version": "0.1.1",
  "description": "微信 Claude Code 助手 - worker-first 的本地微信派活工具，兼容高级 Channels 模式",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "wechat-agent": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "cli": "node dist/cli.js",
    "channels": "node dist/cli.js channels setup",
    "install:guide": "node dist/cli.js install",
    "login": "node dist/cli.js login",
    "service": "node dist/cli.js service",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "node dist/cli.js start",
    "start:daemon": "node dist/cli.js start --daemon",
    "stop": "node dist/cli.js stop",
    "status": "node dist/cli.js status",
    "doctor": "node dist/cli.js doctor",
    "doctor:fix": "node dist/cli.js doctor --fix",
    "release:patch": "npm run build && node dist/release-cli.js patch",
    "release:minor": "npm run build && node dist/release-cli.js minor",
    "release:major": "npm run build && node dist/release-cli.js major"
  },
  "keywords": ["claude-code", "wechat", "channel", "agent", "worker"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
